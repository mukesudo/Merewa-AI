# --- Environment Settings ---
ENVIRONMENT=development
API_PREFIX=/api
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# --- Database & Persistence ---
# Local Docker: postgresql+asyncpg://postgres:password@localhost:5433/merewa_db
# Supabase: postgresql+asyncpg://postgres:[password]@db.[project-ref].supabase.co:5432/postgres
DATABASE_URL=

# --- AI & LLM (Groq / Ollama) ---
LLM_PROVIDER=groq
LLM_MODEL=llama-3.1-8b-instant
GROQ_API_KEY=

# --- Vector Search (Weaviate) ---
WEAVIATE_ENABLED=false
WEAVIATE_URL=
WEAVIATE_API_KEY=

# --- Caching (Upstash Redis) ---
UPSTASH_REDIS_URL=

# --- Security ---
# Must match MEREWA_INTERNAL_API_TOKEN in the frontend
INTERNAL_API_TOKEN=merewa-internal-dev-token

# --- Storage (Supabase) ---
STORAGE_BACKEND=supabase
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=merewa-media

# --- Startup Features ---
SEED_PERSONAS_ON_STARTUP=true
AUTO_SEED_DEMO_DATA=false
