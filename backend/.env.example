# ==============================================================
#  Merewa Backend — Environment Variables
#  Copy this file to .env (dev) or set in Render dashboard (prod)
# ==============================================================

# --- Environment ---
# DEVELOPMENT: development  |  PRODUCTION: production
ENVIRONMENT=development
API_PREFIX=/api

# CORS: comma-separated list of allowed frontend origins
# DEVELOPMENT: http://localhost:3000,http://127.0.0.1:3000
# PRODUCTION:  https://your-app.vercel.app
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# --- Database ---
# Local Docker:  postgresql+asyncpg://merewa:password@127.0.0.1:5433/merewa_db
# Supabase prod: postgresql+asyncpg://postgres:[password]@db.[ref].supabase.co:5432/postgres
DATABASE_URL=

# --- Security ---
# Must match MEREWA_INTERNAL_API_TOKEN in the frontend .env
# PRODUCTION: use a strong random token — openssl rand -hex 32
INTERNAL_API_TOKEN=merewa-internal-dev-token

# --- AI & LLM ---
# LLM_PROVIDER: groq (recommended) or ollama (local only)
LLM_PROVIDER=groq
LLM_MODEL=llama-3.1-8b-instant
# Get your free key at: https://console.groq.com
GROQ_API_KEY=

# --- AI Voice / TTS (optional, for future audio generation) ---
# Recommended for Amharic: Azure Speech or Google Cloud TTS
# AZURE_SPEECH_KEY=
# AZURE_SPEECH_REGION=eastus
# GOOGLE_TTS_CREDENTIALS_JSON=

# --- Storage ---
# DEVELOPMENT: local  |  PRODUCTION: supabase
STORAGE_BACKEND=local
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=merewa-media

# --- Vector Search (Weaviate — optional) ---
WEAVIATE_ENABLED=false
WEAVIATE_URL=
WEAVIATE_API_KEY=

# --- Caching (Upstash Redis — optional) ---
UPSTASH_REDIS_URL=

# --- Startup Behaviour ---
SEED_PERSONAS_ON_STARTUP=true
AUTO_SEED_DEMO_DATA=false
# Set to true on first production deploy to populate demo posts, then set back to false
# AUTO_SEED_DEMO_DATA=true
