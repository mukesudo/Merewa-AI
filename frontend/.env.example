# ==============================================================
#  Merewa Frontend — Environment Variables
#  Copy this file to .env.local (dev) or set in Vercel dashboard (prod)
# ==============================================================

# --- Better Auth Configuration ---
# Generate a strong secret: openssl rand -base64 32
BETTER_AUTH_SECRET=

# DEVELOPMENT: http://localhost:3000
# PRODUCTION:  https://your-app.vercel.app  (exact URL, no trailing slash)
BETTER_AUTH_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Database for Better Auth Session Storage ---
# DEVELOPMENT: leave empty → falls back to local SQLite (auth.db)
# PRODUCTION (required): Supabase PostgreSQL connection string
#   Format: postgresql://postgres:[password]@db.[ref].supabase.co:5432/postgres
DATABASE_URL=
BETTER_AUTH_DATABASE_URL=

# --- Backend Communication ---
# DEVELOPMENT: http://localhost:8000
# PRODUCTION:  https://your-backend.onrender.com  (no trailing slash)
MEREWA_BACKEND_URL=http://localhost:8000

# Must be the same value as INTERNAL_API_TOKEN on the backend
# PRODUCTION: set a strong random value, e.g. openssl rand -hex 32
MEREWA_INTERNAL_API_TOKEN=merewa-internal-dev-token

# --- Social Login Providers (Optional) ---
# GitHub OAuth App: https://github.com/settings/developers
#   Callback URL: https://your-app.vercel.app/api/auth/callback/github
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Google OAuth App: https://console.cloud.google.com/
#   Authorized redirect URI: https://your-app.vercel.app/api/auth/callback/google
#   NOTE: Must add BOTH localhost:3000 and production URL to authorized origins
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- AI Voice / TTS (future) ---
# ELEVENLABS_API_KEY=
# AZURE_SPEECH_KEY=
# AZURE_SPEECH_REGION=
