# --- Better Auth Configuration ---
# Generate a secret with: openssl rand -base64 32
BETTER_AUTH_SECRET=
# The URL of your frontend (e.g., http://localhost:3000 in dev, https://merewa.vercel.app in prod)
BETTER_AUTH_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Database Configuration ---
# Use Supabase PostgreSQL connection string
DATABASE_URL=
# Optionally set a separate URL for Better Auth if needed
BETTER_AUTH_DATABASE_URL=

# --- Backend Communication ---
# The URL of your FastAPI backend
MEREWA_BACKEND_URL=http://localhost:8000
# Must match the INTERNAL_API_TOKEN set in the backend
MEREWA_INTERNAL_API_TOKEN=merewa-internal-dev-token

# --- Social Login Providers (Optional) ---
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
